{
  "name": "ai-blog-system",
  "version": "1.0.0",
  "private": true,
  "description": "AI niche blog with SEO + GEO + monetization",
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start -p 3000",
    "post:generate": "node scripts/generate-post.js",
    "seo:audit": "node scripts/seo-audit.js",
    "indexnow": "node scripts/indexnow-submit.js",
    "smoke": "node scripts/smoke-test.js",
    "smoke:start": "node scripts/smoke-test.js --start-server",
    "workflows:check": "node scripts/validate-workflows.js",
    "links:auto": "node scripts/auto-internal-link.js",
    "seo:optimize": "node scripts/seo-optimizer.js",
    "seo:optimize:fix": "node scripts/seo-optimizer.js --fix",
    "content:strategy": "node scripts/content-strategy.js",
    "content:strategy:fill": "node scripts/content-strategy.js --fill-queue",
    "content:refresh": "node scripts/content-refresher.js",
    "content:refresh:run": "node scripts/content-refresher.js --refresh",
    "intelligence:full": "node scripts/content-refresher.js --refresh && node scripts/seo-optimizer.js --fix && node scripts/auto-internal-link.js && node scripts/seo-audit.js",
    "agent:supervisor": "npx tsx scripts/agents/supervisor-agent.ts",
    "agent:supervisor:batch": "npx tsx scripts/agents/supervisor-agent.ts --batch 10 --concurrency 5",
    "agent:supervisor:dry": "npx tsx scripts/agents/supervisor-agent.ts --batch 3 --dry-run",
    "agent:supervisor:quick": "npx tsx scripts/agents/supervisor-agent.ts --batch 1 --dry-run",
    "agent:rss": "npx tsx scripts/agents/queue/news-rss.ts",
    "agent:rss:dry": "npx tsx scripts/agents/queue/news-rss.ts --limit 3 --dry-run",
    "agent:rss:quick": "npx tsx scripts/agents/queue/news-rss.ts --limit 1 --dry-run",
    "agent:demo": "npx tsx scripts/agents/supervisor-agent.ts --demo --batch 2 --dry-run",
    "agent:full": "npx tsx scripts/agents/queue/news-rss.ts --limit 3 && npx tsx scripts/agents/supervisor-agent.ts --batch 3",
    "agent:full:local": "npx tsx scripts/agents/queue/news-rss.ts --limit 2 --dry-run && npx tsx scripts/agents/supervisor-agent.ts --demo --batch 2",
    "agent:full:dry": "npx tsx scripts/agents/queue/news-rss.ts --limit 2 --dry-run && npx tsx scripts/agents/supervisor-agent.ts --batch 2 --dry-run",
    "queue:status": "npx tsx scripts/queue-status.ts",
    "queue:status:topics": "npx tsx scripts/queue-status.ts --topics"
  },
  "dependencies": {
    "@vercel/analytics": "^2.0.1",
    "dotenv": "^16.4.5",
    "gray-matter": "^4.0.3",
    "lucide-react": "^1.17.0",
    "next": "^14.2.35",
    "next-auth": "^4.24.14",
    "openai": "^4.67.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "recharts": "^3.8.1",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-parse": "^9.0.0",
    "rehype-sanitize": "^6.0.0",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.0",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.1",
    "rss": "^1.2.2",
    "schema-dts": "^1.1.2",
    "unified": "^11.0.5"
  },
  "devDependencies": {
    "@supabase/supabase-js": "^2.107.0",
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.17",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "supabase": "^2.105.0",
    "tailwindcss": "^3.4.13",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
